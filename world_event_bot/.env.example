# World Event Bot — copy to ".env" and fill in values
# All values have defaults — only EDGEFINDER_API_KEY is required for live signals.

# ── EdgeFinder API (required) ─────────────────────────────────────────────────
EDGEFINDER_API_KEY=

# ── Paper bankroll ────────────────────────────────────────────────────────────
STARTING_BALANCE=1000

# ── Kelly sizing ──────────────────────────────────────────────────────────────
KELLY_FRACTION=0.5
MAX_BANKROLL_PCT_PER_TRADE=0.05
RESERVE_PCT=0.30
CORRELATION_CLUSTER_CAP_PCT=0.25
MAX_TRADE_SIZE=200
POLYMARKET_FEE_RATE=0.048

# ── Entry gates ───────────────────────────────────────────────────────────────
MIN_VOLUME_24HR=50000
MAX_PRICE_DRIFT=0.02
MAX_SIGNAL_AGE_HOURS=72
MAX_OPEN_POSITIONS=30

# ── Risk management ───────────────────────────────────────────────────────────
STOP_LOSS_YES_THRESHOLD=0.50

# ── Storage ───────────────────────────────────────────────────────────────────
DB_PATH=polymarket_event_bot.db

# ── Polling intervals ─────────────────────────────────────────────────────────
EDGEFINDER_POLL_INTERVAL_S=300
POSITION_CHECK_INTERVAL_S=30
