# =============================================================
#  GHOST LATTICE v10 — CONFIG
#  T1=WRAITH (contrarian, hourly/15-min AGAINST Binance dev)
#  T2=SPECTER (oracle-lag, 5-min WITH Binance dev)
#  $6.66 flat sizing — CoinDirEngine auto-blocks negative-EV pairs.
#  Fill in CREDENTIALS section below before running.
# =============================================================

# ── CREDENTIALS ──────────────────────────────────────────────
PRIVATE_KEY=YOUR_POLYGON_PRIVATE_KEY_HERE
POLYMARKET_PROXY_ADDRESS=YOUR_POLYMARKET_PROXY_ADDRESS_HERE

# ── CLOB API ─────────────────────────────────────────────────
CLOB_API_KEY=YOUR_CLOB_API_KEY_HERE
CLOB_SECRET=YOUR_CLOB_SECRET_HERE
CLOB_PASSPHRASE=YOUR_CLOB_PASSPHRASE_HERE

# ── TELEGRAM ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# ── MODE ─────────────────────────────────────────────────────
PAPER_TRADE=true
STATS_SINCE=2026-05-01

# ── RESOLVER ─────────────────────────────────────────────────
RESOLUTION_GRACE_SECS=30

# ── TRADE SIZING ─────────────────────────────────────────────
T1_SIZE_USDC=6.66          # flat $6.66 per trade — WRAITH
T2_SIZE_USDC=6.66          # flat $6.66 per trade — SPECTER

# Per-coin T2 sizing
T2_SIZE_BNB=6.66
T2_SIZE_BTC=6.66
T2_SIZE_SOL=6.66
T2_SIZE_XRP=6.66
T2_SIZE_ETH=6.66

# ── ENTRY PRICE CEILINGS / FLOORS ────────────────────────────
T1_MAX_ENTRY=0.22          # contrarian ceiling (19-22¢ zone: 50% WR)
T2_MAX_ENTRY=0.12          # oracle-lag ceiling
T1_MIN_ENTRY=0.03          # contrarian floor
T2_MIN_ENTRY=0.04          # 4¢ floor — ≤3¢ zone: 66 live trades 0 wins -$4.37/trade

# ── 5-MINUTE MARKET OVERRIDES ────────────────────────────────
T2_5M_MAX_ENTRY=0.18       # whale specialists (0x65d887fc, 0x931cd225) operate 15-20¢
T2_5M_MIN_NO=0.90
T2_5M_WINDOW_SEC=45

# ── PRICE DEVIATION REQUIRED ─────────────────────────────────
T1_MIN_DEV=0.001
T2_MIN_DEV=0.001           # requires Binance momentum, cuts phantom fires

# ── STALE-ASK SNIPE WINDOW (T2) ──────────────────────────────
T2_MAX_SECS_LEFT=55
T2_MIN_SECS_LEFT=8

# ── TIME WINDOWS ─────────────────────────────────────────────
T1_WINDOW_MIN=20
T2_WINDOW_MIN=15
T1_MIN_SECS_LEFT=180

# ── LIQUIDITY FLOOR ──────────────────────────────────────────
LIQ_MULT=1.2
KILL_LIQ_MIN=1.0

# ── ACTIVE KILL FILTERS ───────────────────────────────────────
KILL_SECS_MIN=3.0
KILL_COOLDOWN_SECS=8.0
ELITE_COOLDOWN_BYPASS=true

# ── ENHANCED TREND DETECTION ─────────────────────────────────
TREND_ENHANCED=true
TREND_N_TICKS=10
TREND_VELOCITY_MIN=0.00006
TREND_MOMENTUM_MIN=0.03
TREND_VOLATILITY_MIN=0
TREND_VOLATILITY_MAX=999

# ── 15-MINUTE PUNISHER FILTER ────────────────────────────────
DEV_15M_THRESH=0.0030

# ── SIGNAL PRIORITY RANKING ──────────────────────────────────
TOP_SIGNALS_PER_CYCLE=12

# ── RISK CONTROLS ────────────────────────────────────────────
MAX_OPEN_POSITIONS=8
DAILY_LOSS_LIMIT=350
MAX_TRADES_PER_COIN_DAY=0
SCAN_INTERVAL=0.25
MAX_BET_SIZE=6.66
DYNAMIC_SIZING=false          # disable confidence multiplier
SEG_TRACKING_ENABLED=false    # disable segment multiplier

# ── ADAPTIVE RISK (loss-streak protection) ───────────────────
ADAPTIVE_RISK=true
LOSS_STREAK_REDUCE=5
LOSS_STREAK_PAUSE=10
LOSS_PAUSE_MINUTES=15
LOSS_SIZE_FACTOR=1.0

# ── HOUR BIAS GATE ───────────────────────────────────────────
HOUR_BIAS_ENABLED=true
HOUR_BIAS_MIN_WR=0.58
HOUR_BIAS_MIN_SAMPLES=5
HOUR_BIAS_REFRESH_MIN=10
HOUR_BIAS_LOOKBACK_DAYS=30
HOUR_BIAS_RECENT_DAYS=7
HOUR_BIAS_RECENT_WEIGHT=2.0

# ── BIAS-AWARE FILTERS ───────────────────────────────────────
BIAS_FILTERS=true
SKIP_DOWN_BIASED_COINS=ETH,BTC,BNB,XRP,SOL        # pre-seed for CoinDirEngine; engine adapts dynamically
SKIP_COINS=
DEAD_UP_HOURS_ET=
DEAD_DOWN_HOURS_ET=
HOUR_BOOST_HOURS_ET=18,20,23
HOUR_BOOST_FACTOR=1.06
HOUR_REDUCE_HOURS_ET=0,5,9,12,19

# ── COIN DIRECTION ENGINE — dynamic auto-blocker ─────────────
# Reads live DB every 60s, blocks coin+direction pairs with EV < -0.50/trade
# over the last 200 settled trades (min 20 T2 samples to activate).
COIN_DIR_REFRESH_SECS=60
COIN_DIR_LOOKBACK=200
COIN_DIR_MIN_TRADES=10
COIN_DIR_MIN_TRADES_T2=10  # blocks bad T2 pairs after 10 samples (was 20 — never activated)
COIN_DIR_EV_THRESH=-0.50

# ── BULL REGIME ───────────────────────────────────────────────
# When true: CoinDir never blocks UP signals (DOWN still EV-filtered).
# Flip to false if BTC drops below $60k or market turns bear.
BULL_REGIME=true

# ── NEWS CALENDAR ALERTS ─────────────────────────────────────
NEWS_CALENDAR_ENABLED=true
NEWS_ALERT_CURRENCIES=USD
NEWS_ALERT_MINS_EARLY=60
NEWS_ALERT_MINS_IMMINENT=5

# ── CONFIDENCE GATE ──────────────────────────────────────────
CONFIDENCE_MIN=0.65

# ── ORACLE ARBITRAGE ENGINE ──────────────────────────────────
# ARB_ENABLED=false — gate removed; compute_arb_score still feeds fair_p + confidence
ARB_OVERRIDE_SCORE=0.70       # used for ELITE_COOLDOWN_BYPASS threshold
ARB_RECENCY_WINDOW=30.0       # used in compute_arb_score
ARB_RECENCY_BOOST=2.0
ARB_VEL_BOOST_SCALE=0.00005

# ── ENGINE ───────────────────────────────────────────────────
LAZY_ORDERBOOK=false          # evaluate BOTH UP and DOWN tokens per market
PREWARM_ORDERBOOKS=true
WS_ENABLED=true
WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POSITION_POLL_INTERVAL=5

# ── REDEEMER GAS ─────────────────────────────────────────────
REDEEM_GAS_FLOOR_GWEI=50
REDEEM_GAS_MULT=1.3
REDEEM_GAS_MULT_RETRY=2.0
REDEEM_GAS_CAP_GWEI=300

# ── WHALE / SMART WALLET DISCOVERY ───────────────────────────
WHALE_WALLETS=0x8d2d7bae900cc62bbac531f900dbf58a6f8c5517,0x88e48ee52e549fa106f57dcbe5ef0494eaa2370a,0xbecca2cf118da48c84faf823291269d2d908f37e,0x0fe40e887acbd0022f89d996acce26ab428501b7,0x65d887fcfb195022ddc1084b8063027300e6b2dd,0x06dc51826bc524d9a83770e7de9dd7e005b04524,0x931cd2259731f65ff31faa5233f446b9f50ca002
WHALE_SIGNAL_TTL=120
WHALE_PRIORITY_BOOST=1.20
WHALE_CONF_BOOST=0.03

# ── T3 DOUBLE — insurance hedge on already-open positions ────────────────────
# Fires $1.50 on the OPPOSITE leg of an already-open position when its ask is
# in the cheap range. Bypasses SKIP_DOWN_BIASED_COINS, HourBias, CoinDir,
# confidence, freshness, and cooldown gates. Reduces downside when original
# leg loses. Tier=3 in DB → dashboard shows "DOUBLE".
T3_DOUBLE_ENABLED=true
T3_DOUBLE_MIN_ENTRY=0.05
T3_DOUBLE_MAX_ENTRY=0.08
T3_DOUBLE_SIZE_USDC=1.50
