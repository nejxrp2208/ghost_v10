# Copy this to .env and fill in your values.
# Variable names match what the code actually reads — DO NOT rename without
# updating GHOST_LATTICE.py / resolver / redeemer.

# ── CREDENTIALS (required for LIVE mode; paper mode can leave blank) ────────
PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# ── TELEGRAM ALERTS (optional — leave blank to disable) ────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── MODE ────────────────────────────────────────────────────────────────────
PAPER_TRADE=true

# ── HOUR FILTER (UTC) — only trade during these hours ───────────────────────
# Data (n=2116 trades): only 4 UTC hours are profitable.
# Empty = trade all hours (default off). Set to restrict scanning.
ALLOWED_HOURS=1,3,15,23

# ── TRADE SIZING (flat USDC per trade) ─────────────────────────────────────
T1_SIZE_USDC=4.00
T2_SIZE_USDC=4.00
