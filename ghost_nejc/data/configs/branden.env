# Branden's LIVE Ghost Predator config — strategy params, COPY FREELY.
# Secrets/keys/wallet/balances REMOVED — add your OWN before running:
#   wallet private-key, proxy + relayer addresses, signature type, builder code,
#   CLOB api creds (key/secret/passphrase), telegram bot token + chat id,
#   and your starting balance / initial deposit.
# Verified from live VPS .env 2026-06-18. Schema/explanations: configs/branden.yaml + _schema.yaml.

PAPER_TRADE=false

# coins & windows
COINS=BTC,ETH
DURATIONS=5m,15m
SNIPE_WINDOW_SECS=12
SNIPE_WINDOW_15M=12
MIN_FILL_SECS=2
LATE_FIRE_SECS=0

# entry band + move filter
MIN_MOVE_BPS=1.5
WEEKEND_MIN_MOVE_BPS=1.5
MIN_ASK=0.50
MAX_ASK=0.75
FILL_FLOOR=0.50

# sizing / ladder
BASE_SIZE=10.0
MIN_STAKE=1.0
DYNAMIC_SIZE=true
MAX_PER_MARKET=25.0
PAROLI_ENABLED=true
PAROLI_LADDER=10,15
PAROLI_STEPS=3
PAROLI_MULT=1.5
PAROLI_5M_MAX_STEP=1
REQUIRE_FILL=true
WALK_FILL=true
WALK_CAP=0

# filters / gates
MIN_BOOK_DEPTH=50
MIN_CONFIRMS=2
CHOP_FILTER=false
CHOP_MAX_FLIPS=4
CHOP_LOOKBACK=90
CONVICTION_GATE=false
EDGE_FILTER_MIN=0
REGIME_GATE=false
REGIME_WINDOW=15
FAT_ASK_THRESHOLD=0.90
STAKE_THIN_RATIO=1.0

# guardrails
DAILY_LOSS_LIMIT=150
MAX_LOSS_STREAK=10
MIN_BALANCE=150
ROLLING_24H_LIMIT=0
MAX_OPEN_POSITIONS=5

# scratch (wire-race breach exit)
AUTO_SCRATCH=true
SCRATCH_MAX_SLIP=0.15
SCRATCH_SETTLE_S=1.5
SCRATCH_RETRIES=3

# skips
SKIP_ETH_UP=false
SKIP_BTC_UP=false
ETH_SKIP_15M=false
BTC_SKIP_5M=false

# schedule (TRADING_HOURS empty = all hours; blackout likely dead config)
TRADING_HOURS=
BLACKOUT_START=21
BLACKOUT_END=23

# cadence / feed
USE_WSS_BOOK=true
BOOK_POLL_MS=10
DISCOVERY_SECS=20
PRICE_MAX_AGE=3.0
REAL_TRADING_PAUSED=false
ASK_LOG=true
