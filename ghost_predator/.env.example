# GHOST PREDATOR — latency-snipe config. Copy to ".env" and edit.
# ─────────────────────────────────────────────────────────────────────────────

# Mode: paper = simulated fills (no money, no creds). Set false for live (VPS).
PAPER_TRADE=true
STARTING_BALANCE=1000

# Coins to snipe. Only ones we have a Binance feed for (BTC/ETH/SOL/XRP/BNB).
# BTC/ETH validated live; SOL/XRP validated on shadow data 2026-06-05..25 (n~5200).
# Every coin listed here gets its own {COIN}_* override keys (see per-coin section).
COINS=BTC,ETH,SOL,XRP

# Market durations. Both 5m and 15m validated (correct-close backtest):
# 5m ~75-80% win +132-186% ROI; 15m ~75-78% win +42-58% ROI. 5m is stronger.
DURATIONS=5m,15m

# ── Snipe timing (from backtest: T-5s..T-10s is the sweet spot) ──────────────
SNIPE_WINDOW_SECS=28     # 2026-05-25 EXPERIMENT ARM (Mac only — VPS stays 12 = baseline). Live-checking
                         #   T-30s for 1 week. Our 2,416-market backtest refuted the T-60s claim (under the
                         #   0.65-0.85 cap widening only ~1.7x'd fires, not 6x; total ~flat T-12s->T-30s,
                         #   worse beyond). T-30s is the only window with marginal gross support — testing
                         #   whether its frequency edge survives LIVE fills (which the backtest can't see).
                         #   Compare Mac(T-30) vs VPS(T-12). Revert to 12 to rejoin baseline.
SNIPE_WINDOW_15M=30      # 2026-05-22: 15m markets snipe wider (T-30s) — at 30s a 15m
                         #   window is 96.7% done so the outcome is settled, but the quote
                         #   is fresher / less contested than the last-second sub-1ms scrum.
                         #   5m stays tight at 12s (T-30s on a 5m is only 10% done = too unsettled).
MIN_FILL_SECS=5          # never fire with less than this left (need time to land order)

# ── Edge filters ─────────────────────────────────────────────────────────────
# 2026-05-22: tightened after trade #13 (BTC Down @ 0.08, -0.2bps "lead", -$30).
#   That was a noise-level tape lead the BOOK had written off (8c). Two gates fix it:
MIN_MOVE_BPS=1.0         # require a REAL move (>=0.01%), not a 0.2bps noise wobble.
MAX_MOVE_BPS=0           # global MAX band: skip if |move| > this. Giant moves are already
                         #   repriced by PM before we fire (data: BTC 6+bps edge -17%,
                         #   SOL 4-6bps edge -14%). 0 = disabled. Per-coin override below.
# ── Hour TIERS (UTC) — three classes of hours, each with its OWN ladder ──────
# GOLDEN hours  -> best edge  -> biggest ladder ({COIN}_{DUR}_GOLDEN_LADDER_STEPS)
# normal hours  -> everything not golden/blocked -> classic ladder
# BLOCKED hours -> worst edge -> MINIMAL ladder (default 1,2,3) — still trades,
#                  just tiny (keeps collecting data at minimum risk). Only when
#                  LADDER_ENABLED=false do blocked hours hard-skip instead.
# ALLOWED_HOURS is separate and HARD: if set, hours outside it NEVER trade.
GOLDEN_HOURS=            # global golden hours, comma-sep (e.g. "13,14,15,16"). Empty = none.
BLOCKED_HOURS=           # global blocked hours (minimal ladder). Empty = none.
ALLOWED_HOURS=           # global HARD whitelist: if set, trade ONLY these UTC hours. Empty = all hours.

# ── Per-coin overrides ───────────────────────────────────────────────────────
# Every coin in COINS reads its own {COIN}_* keys. Absent or EMPTY key = inherit
# the global value. A SET key fully REPLACES the global one for that coin.
# Data below: shadow collector 2026-06-05..25 (ask 0.65-0.78, $20 stake), edge = WR - avg entry.
#
# BTC — the star: 5m edge +4.0% (n=436 fills), 15m edge +16.3% (n=45, small sample).
#   Golden bps band 1.0-2.5 (up to 3.0 on fills); 6+bps toxic (edge -17%).
#   Golden hours UTC: 13-16 block (16h = 95.6% WR), 08, 11, 20. Toxic: 17, 22, 23, 00, 07, 19.
BTC_MIN_MOVE_BPS=1.0
BTC_MAX_MOVE_BPS=6.0     # cut the toxic 6+bps giant moves
BTC_SKIP_5M=false
BTC_SKIP_15M=true        # legacy live data said 15m loser (n=19); shadow says +16.3% (n=45) — flip when convinced
BTC_GOLDEN_HOURS=8,11,13,14,15,16,20   # golden block 13-16 UTC (16h = 95.6% WR +22% edge)
BTC_BLOCKED_HOURS=0,7,17,19,22,23      # toxic hours -> minimal ladder (17h edge -10.4%)
BTC_ALLOWED_HOURS=       # HARD whitelist — leave empty unless you want BTC to trade ONLY listed hours
#
# ETH — flat: 5m edge +1.6% (n=497), 15m -0.9% (n=53). No clean bps band
#   (only 2.5-3.0 positive; 3-4 toxic -7.5%). Golden hours: 04, 08, 11, 17. Toxic: 18, 01, 12, 20, 23.
ETH_MIN_MOVE_BPS=1.0
ETH_MAX_MOVE_BPS=0
ETH_SKIP_5M=false
ETH_SKIP_15M=true        # 54% WR = coinflip, Chainlink disagree
ETH_GOLDEN_HOURS=4,8,11,17             # 04h edge +12.2%, 11h +10.4%
ETH_BLOCKED_HOURS=1,12,18,20,23        # toxic -> minimal ladder (18h edge -12.6%)
ETH_ALLOWED_HOURS=
#
# SOL — NEGATIVE without filters: 5m edge -1.4% (n=570), 15m -0.7% (n=64).
#   Only worth trading WITH hour+band gates. Golden bps 1.0-1.5 (+5.3%) and 3-4 (+2.0%);
#   4-6bps toxic (edge -14.3%, -$369!). Golden hours: 04, 05, 06, 14, 21. Toxic: 01, 03, 07, 12, 15, 17.
SOL_MIN_MOVE_BPS=1.3     # shadow-tested gate
SOL_MAX_MOVE_BPS=4.0     # cut the -14% 4-6bps band
SOL_SKIP_5M=false
SOL_SKIP_15M=true        # 15m edge -0.7% = no edge
SOL_GOLDEN_HOURS=4,5,6,14,21           # 06h edge +12.7%, 04h +11.3%, 21h +11.5%
SOL_BLOCKED_HOURS=1,3,7,12,15,17       # toxic -> minimal ladder
SOL_ALLOWED_HOURS=       # stricter alternative: set to 4,5,6,14,21 to trade ONLY golden hours
#
# XRP — worth adding: 5m edge +2.6% (n=515 fills), 15m +2.4% (n=68).
#   Golden bps 1.5-2.0 (+2.4%) and 4-6 (+12.5%, n=55); 2.5-3.0 negative, 6+ weak.
#   Golden hours: 10, 11, 13, 15, 18, 20 (+17%), 23. Toxic: 12 (-13%), 00 (-11%), 01, 05, 08, 22.
XRP_MIN_MOVE_BPS=1.5     # shadow-tested gate (1.0-1.5 band never collected for XRP)
XRP_MAX_MOVE_BPS=0       # 4-6bps is XRP's GOLDEN band — do not cap it
XRP_SKIP_5M=false
XRP_SKIP_15M=false       # 15m edge +2.4% (n=68) — the only coin where 15m looks alive
XRP_GOLDEN_HOURS=10,11,13,15,18,20,23  # 20h edge +17%, 11h +12.6%
XRP_BLOCKED_HOURS=0,1,5,8,12,22        # toxic -> minimal ladder (12h edge -13.3%)
XRP_ALLOWED_HOURS=
MIN_ASK=0.65             # 2026-05-23: 0.50 -> 0.65. Data (n=11) showed the 0.50-0.65 "coinflip" band
                         #   wins only 55% but needs ~57% just to break even = net -$0.40/trade. No
                         #   edge at coinflip prices — the market prices the outcome correctly and the
                         #   "leader already decided" thesis fails on tiny moves near the open. Cutting
                         #   it; the 0.65-0.78 (80% win) and 0.78-0.86 (95%, +$3.80/trade) bands carry
                         #   the edge. (Reverses the earlier keep-0.50 call, which rested on one winner.)
MAX_ASK=0.85             # upper cap for profit room. Buy window is 0.50-0.85.

# ── Sizing ───────────────────────────────────────────────────────────────────
BASE_SIZE=30.0           # 2026-05-27: reverted 60 -> 30. In PAPER, bigger size only scaled the swings (and $60-or-skip biased the sample to deep books). $30 = cleaner sample + matches a sane initial live size.
MAX_PER_MARKET=30.0      # 2026-05-27: reverted 60 -> 30 to match BASE_SIZE.
REQUIRE_FILL=true        # only fire/record when resting depth covers the full stake (fixed-size mode).
                         #   Superseded by DYNAMIC_SIZE below when that is true.
DYNAMIC_SIZE=true        # 2026-05-23: size each order to the depth at the ask = min(BASE_SIZE, depth),
                         #   so the FOK fills in full (~100% fill). This captures thin HIGH-WIN books
                         #   at small size instead of skipping them — backtest on 47 fills flipped the
                         #   fee-adjusted net from -$24 to +$39 (+5.2% on capital). BASE_SIZE = the cap.
                         #   NOTE: live, you race other takers for thin depth — speed (WSS/colo) decides
                         #   how much you actually capture. false = fixed BASE_SIZE + REQUIRE_FILL gate.
# Per-coin stake + exposure (IGNORED when LADDER_ENABLED=true). Empty = global BASE_SIZE/MAX_PER_MARKET.
BTC_BASE_SIZE=12.0       # data: BTC 82% WR -> biggest stake
ETH_BASE_SIZE=7.0        # data: ETH 64% WR -> smaller stake
SOL_BASE_SIZE=5.0        # new coin — start small until live-validated
XRP_BASE_SIZE=5.0        # new coin — start small until live-validated
BTC_MAX_PER_MARKET=12.0
ETH_MAX_PER_MARKET=7.0
SOL_MAX_PER_MARKET=5.0
XRP_MAX_PER_MARKET=5.0

# ── Compounding ladder (per coin × duration) ────────────────────────────────
# Win advances to next step. Loss resets to step 1. Last step cycles back to 1.
# Example default [10,15,25]: $10 → win → $15 → win → $25 → next is $10 (cycle).
# Each (coin, duration) tracks its OWN position based on resolved trade history
# (DB-derived, survives restarts). When LADDER_ENABLED=true, {COIN}_BASE_SIZE
# is IGNORED — ladder is the sole sizing source. Missing key = default 10,15,25.
#
# THREE ladders per (coin, duration) — the current hour tier picks which one:
#   GOLDEN hours  -> {COIN}_{DUR}_GOLDEN_LADDER_STEPS  (fallback: GOLDEN_LADDER_STEPS, then classic)
#   normal hours  -> {COIN}_{DUR}_LADDER_STEPS         (the classic ladder)
#   BLOCKED hours -> {COIN}_{DUR}_BLOCKED_LADDER_STEPS (fallback: BLOCKED_LADDER_STEPS, default 1,2,3)
# Each tier climbs INDEPENDENTLY: only trades fired in that tier's hours advance or
# reset that tier's ladder — a $1 blocked-hour probe never touches the golden ladder.
LADDER_ENABLED=true
GOLDEN_LADDER_STEPS=         # global golden fallback. Empty = golden uses the classic ladder.
BLOCKED_LADDER_STEPS=1,2,3   # global blocked fallback — minimal probe stakes.
# classic (normal hours)
BTC_5M_LADDER_STEPS=10,15,25
BTC_15M_LADDER_STEPS=10,15,25
ETH_5M_LADDER_STEPS=10,15,25
ETH_15M_LADDER_STEPS=10,15,25
SOL_5M_LADDER_STEPS=5,8,12   # new coin — conservative ladder until live-validated
SOL_15M_LADDER_STEPS=5,8,12
XRP_5M_LADDER_STEPS=5,8,12
XRP_15M_LADDER_STEPS=5,8,12
# golden hours — biggest stakes (data: these hours carry the edge)
BTC_5M_GOLDEN_LADDER_STEPS=15,25,40
BTC_15M_GOLDEN_LADDER_STEPS=15,25,40
ETH_5M_GOLDEN_LADDER_STEPS=12,18,30
ETH_15M_GOLDEN_LADDER_STEPS=12,18,30
SOL_5M_GOLDEN_LADDER_STEPS=8,12,20
SOL_15M_GOLDEN_LADDER_STEPS=8,12,20
XRP_5M_GOLDEN_LADDER_STEPS=8,12,20
XRP_15M_GOLDEN_LADDER_STEPS=8,12,20
# blocked hours — minimal probes (uncomment to override the global 1,2,3 per coin)
#BTC_5M_BLOCKED_LADDER_STEPS=1,2,3
#BTC_15M_BLOCKED_LADDER_STEPS=1,2,3
#ETH_5M_BLOCKED_LADDER_STEPS=1,2,3
#SOL_5M_BLOCKED_LADDER_STEPS=1,2,3
#XRP_5M_BLOCKED_LADDER_STEPS=1,2,3
MIN_STAKE=1.0            # Polymarket min order; if depth-matched size is below this, skip (truly unfillable)
FILL_FLOOR=0.50          # safety floor on blended walk-fill entry price. 0 = disabled.
                         #   Prevents stale WSS book levels dragging blended avg below this threshold.
                         #   (observed: best_ask passed 0.65 gate but stale levels → blended fill at 0.46)
WALK_FILL=true           # 2026-05-25: walk the ask ladder to fill the FULL BASE_SIZE ($30) within MAX_ASK at a
                         #   blended avg entry (realistic multi-level FOK). Fire ONLY if the in-band book supplies
                         #   the full $30 ("$30 or skip") — thin books that can't are skipped (a live FOK would miss
                         #   them, and their tiny wins die to live slippage/fees). Supersedes DYNAMIC_SIZE shrink.

# ── Account-survival guardrails (so a bad run can NEVER drain the account) ───
DAILY_LOSS_LIMIT=60      # halt for the UTC day if today's PnL <= -$60
MAX_LOSS_STREAK=5        # halt if 5 losses in a row (edge broke guard)
MIN_BALANCE=0            # halt if balance below this; 0 = floor at one stake
ROLLING_24H_LIMIT=50     # halt if rolling-24h PnL <= -$50 (true rolling window, not UTC-day reset; 0 = disabled)

# ── Edge gate (regime detector) ──────────────────────────────────────────────
REGIME_GATE=true         # master switch. true = only bet real money when edge >= 0, else paper-watch
REGIME_WINDOW=15         # last-N resolved real trades used to measure edge (data: 15 is backtest-optimal)

# ── First-Mover Detector (radar-based "green light") ─────────────────────────
# Reads divergence.db and computes rolling realized edge on last N=20 windows where
# the PM favorite was priced in [MIN_FAV_ASK, MAX_FAV_ASK]. Signals GO/WAIT/OUT.
# When ENABLED=true, real fires only happen when signal=GO or WARMUP (default ON).
# Run as separate PM2 process: ghost-predator-firstmover (writes firstmover_state.json).
FIRSTMOVER_ENABLED=false      # set true to gate real bets on first-mover signal
FIRSTMOVER_WINDOW=20          # last N resolved divergence windows (K=20 = backtest-optimal)
FIRSTMOVER_MIN_FAV_ASK=0.60   # favorite ask band lower (broader than predator's MIN_ASK)
FIRSTMOVER_MAX_FAV_ASK=0.85   # favorite ask band upper
FIRSTMOVER_GO=0.08            # rolling_edge ≥ +8% → GO (fresh mispricing, fire real)
FIRSTMOVER_OUT=0.00           # rolling_edge < 0% → OUT (decayed, paper-watch)
FIRSTMOVER_POLL_SECS=60       # how often firstmover.py recomputes from radar DB

# ── Cadence ──────────────────────────────────────────────────────────────────
USE_WSS_BOOK=true        # 2026-05-23: real-time order book via Polymarket CLOB WSS market channel.
                         #   Reads the ask from memory (microseconds) and NEVER misses depth that
                         #   appears+vanishes between REST polls (~470 book updates/s vs 20/s on REST).
                         #   Fast-path only: if the feed lags/drops, best_ask falls back to REST below,
                         #   so it can only improve fills, never break a fire. Flip false = exact old REST.
BOOK_POLL_MS=10          # 2026-05-23: 50->10ms. This is the snipe-loop SWEEP cadence (how often
                         #   the bot re-checks the in-window ask). With the WSS feed reads are free
                         #   (0ms from memory), so we spin 5x faster to react to the real-time book —
                         #   cuts decision-to-fire lag from ~25ms avg to ~5ms. Safe at 10ms: swept
                         #   books are answered by WSS (authoritative), so REST isn't hammered.
DISCOVERY_SECS=20        # how often to refresh the active-market list + open prices
PRICE_MAX_AGE=3.0        # 2026-05-22: skip trading if the Binance price is older than this
                         #   (stale-feed guard — never fire on a frozen quote during a feed gap)

# ── Telegram (optional — pings on each snipe). Leave blank to disable. ───────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Live credentials (ONLY needed if PAPER_TRADE=false) ──────────────────────
PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=
