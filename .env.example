# ============================================================
#  CRYPTO GHOST SCANNER — v111 OVERLAY (2026-04-25)
#
#  Strategy adopted from friend's live bundle (v111).
#  Path A modified: cheapest token + trend match + 5-min markets,
#  fire only in last 3 minutes when MIN_NO_PRICE >= 0.97.
#
#  YOUR wallet creds preserved at the bottom — friend's keys
#  removed. PAPER_TRADE forced ON until 100+ trades validate.
#
#  Backup of pre-overlay config:
#    _backup_pre_v111_overlay_20260425_160124/.env
# ============================================================

# ── MODE ────────────────────────────────────────────────────
PAPER_TRADE=true

# ── PAPER TRADING PORTFOLIO ──────────────────────────────────
PORTFOLIO_SIZE=200.00

# ── STRATEGY TOGGLE ─────────────────────────────────────────
# Friend's bundle is implicit Path A (their scanner doesn't read STRATEGY).
# Our overlaid scanner is the same as friend's — no STRATEGY env needed.
# Setting it anyway for clarity in case anything downstream looks for it.
STRATEGY=A

# ── TRADE SIZING ─────────────────────────────────────────────
T1_SIZE_USDC=5.0
T2_SIZE_USDC=3.0
T3_SIZE_USDC=3.0
T4_SIZE_USDC=2.0

# Per-coin T2 overrides (data-backed from 236-trade history).
# Trading BTC / ETH / BNB only. SOL and XRP removed entirely.
T2_SIZE_BTC=5.0
T2_SIZE_ETH=3.0
T2_SIZE_BNB=3.0

# ── ENTRY PRICE CEILINGS (FRIEND v111) ──────────────────────
# Cheap longshot only. $0.03 ceiling on T1/T2.
T1_MAX_ENTRY=0.03
T2_MAX_ENTRY=0.03
T3_MAX_ENTRY=0.15
T4_MAX_ENTRY=0.20

# ── CERTAINTY FLOOR ─────────────────────────────────────────
# Friend's tightest filter — the OTHER side must be >=97% certain
# before we'll consider buying the cheap side.
MIN_NO_PRICE=0.97

# ── LIQUIDITY FLOOR ─────────────────────────────────────────
MIN_LIQUIDITY=0.50

# ── TIME WINDOWS ────────────────────────────────────────────
# T2_WINDOW_MIN=3 = only fire in the LAST 3 MINUTES of a market.
# This is the key mispricing window: Binance has moved, PM hasn't.
T2_WINDOW_MIN=3
T3_WINDOW_MIN=60
T4_WINDOW_MIN=240

# ── PRICE DEVIATION REQUIRED ─────────────────────────────────
T2_MIN_DEV=0.000
T3_MIN_DEV=0.005
T4_MIN_DEV=0.004

# ── RISK CONTROLS ────────────────────────────────────────────
DAILY_LOSS_LIMIT=999999.0  # OFF for paper-mode 500-trade collection. Restore to 50.0 before going live.
MAX_OPEN_POSITIONS=20
SCAN_INTERVAL=1.0          # 3.0 → 1.0: 3x more scans/min for stale-ask racing

# v9.5 STRIKE_SCAN_ENABLED=false — disables the StrikePreloader entirely.
# T1 strike-crossing markets aren't firing for you anyway. Saves ~6s
# at startup and keeps the bot focused on T2 5-min markets.
STRIKE_SCAN_ENABLED=false

# v10 WebSocket orderbook subscription — pushes order-book updates to
# the bot in ~50ms instead of polling. Subscribes to in-window markets
# automatically. Set WS_ENABLED=false to fall back to polling.
WS_ENABLED=true
WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ── PM GAMMA VERIFICATION (DISABLED) ─────────────────────────
# Gamma /markets endpoint defaults to active markets only and does
# not expose resolved outcomes for closed markets. PM_VERIFY can't
# actually verify, so it stays off. Chainlink-direct is the source.
PM_VERIFY=false
PM_VERIFY_DELAY=60
PM_VERIFY_RETRY=5
PM_VERIFY_BACKOFF=45

# ── BIAS-AWARE FILTERS (from 5,852-market pooled data) ───────
# Pooled stats: BNB 88.5% UP, ETH 72.7% UP, BTC 65.8% UP.
# Cheap-DOWN on BNB is bad EV → kept on.
# Hour-of-day filters DISABLED — bot trades 24/7 regardless of session.
BIAS_FILTERS=true
# Skip cheap-DOWN on these coins. BNB: 88.5% UP base rate.
# ETH: data-empirical 11% WR on cheap-DOWN trades (vs 75% on cheap-UP).
SKIP_DOWN_BIASED_COINS=BNB,ETH
DEAD_UP_HOURS_ET=
DEAD_DOWN_HOURS_ET=

# v10.2 stale-ask snipe — fire only when secs_left is in this window.
# Data: 53% WR at 0-30s, 22% at 30-60s, 0-20% beyond.
T2_MAX_SECS_LEFT=60
T2_MIN_SECS_LEFT=5

# ── ENGINE FLAGS ─────────────────────────────────────────────
# Lazy orderbook: predict direction from trend, fetch only 1 book (saves ~85% HTTP).
LAZY_ORDERBOOK=true
# Pre-warm orderbook 60s before T2 snipe window opens.
PREWARM_ORDERBOOKS=true
# Use wallet activity feed as a market discovery source (in addition to direct scan).
WALLET_DISCOVERY=false

# ── ENTRY PRICE FLOOR (V2 port) ──────────────────────────────
# Skip tokens priced below this — near-zero asks are near-certain losers.
MIN_ENTRY_PRICE=0.008

# ── DIRECTION MULTIPLIERS (V2 port) ──────────────────────────
# Apply multiplier to T2_MAX_ENTRY per direction.
# Set UP_MAX_ENTRY_MULT<1 to tighten the UP side (UP historically weaker).
UP_MAX_ENTRY_MULT=1.0
DOWN_MAX_ENTRY_MULT=1.0

# ── MOMENTUM GATE (V2 port, default OFF) ─────────────────────
# When TREND_ENHANCED=true: refuses to fire if Binance is reversing at entry.
# L23 forensics: 92/115 losses had price reversing after entry (0% WR).
# Enable only after collecting enough tick history (wait ~5 min after start).
TREND_ENHANCED=false
TREND_N_TICKS=10            # ring buffer size per coin
TREND_MOMENTUM_MIN=0.30     # fraction of ticks that must agree with direction
TREND_VELOCITY_MIN=0.0000005  # price must be moving (not stalled)

# ── REGIME GATE (V2 port, requires ghost_regime_sentinel.py) ─
# Halts firing when BOTH BTC and ETH 5m vol are below threshold.
# Data source: regime_log table in agent_reports.db.
# Leave OFF until sentinel has collected >=14 days of data.
TREND_REGIME_GATE=false
TREND_REGIME_VOL_MIN=0.0005   # 0.05% 5m vol threshold
TREND_REGIME_MAX_AGE_S=600    # fail-open if sentinel data older than this

# ── REGIME SENTINEL CONFIG (ghost_regime_sentinel.py) ────────
REGIME_POLL_SEC=300     # observation interval (5 min)
REGIME_N_CANDLES=12     # candles per observation (12 × 5m = 1 hour)

# ── BINANCE REST OVERRIDE ────────────────────────────────────
# Default: https://api.binance.com/api/v3 (correct global endpoint).
# Only override if you know what you're doing.
# BINANCE_REST=https://api.binance.com/api/v3

# ============================================================
#  YOUR WALLET — PRESERVED FROM PRE-OVERLAY .env
#  DO NOT replace with friend's keys.
# ============================================================
PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
FUNDER_ADDRESS=

# ── YOUR API CREDS ──────────────────────────────────────────
API_KEY=
API_SECRET=
API_PASSPHRASE=

# ── OPTIONAL TELEGRAM ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
#  SCANNER 2 — Mean-Reversion Mid-Probability Strategy
#  File: crypto_ghost_scanner2.py  |  PM2: scanner2  |  tier=5
#
#  Signal: when coin deviates >S2_TREND_THRESHOLD in 1h,
#  buy the opposing side at mid-probability (0.35–0.45).
#  Data: trend_1h < -0.3% → buy UP wins 69.8% | > +0.4% → buy DOWN 62.4%
# ============================================================
S2_ENTRY_MIN=0.35          # min ask to enter (mid-probability zone)
S2_ENTRY_MAX=0.45          # max ask to enter
S2_TREND_THRESHOLD=0.003   # 0.3% 1h deviation required to trigger
S2_WINDOW_SECS=120         # fire in last 2 minutes of market
S2_SIZE_USDC=3.0           # position size per trade
S2_MIN_LIQUIDITY=10.0      # min $ liquidity at ask (higher than S1)
S2_COINS=BTC,ETH,BNB,XRP,SOL  # active coins for Scanner 2
S2_SCAN_INTERVAL=5.0       # scan every 5s (less urgent than S1)
