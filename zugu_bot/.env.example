# ── General mode ─────────────────────────────────────────────────────────────
PAPER_TRADE=true
PORTFOLIO_SIZE=200.0
QUIET_MODE=false
FL_RESET_ON_START=false

# ── FOLLOW LEADER strategy (late-candle momentum) ────────────────────────────
# Backtest result on ~465 candles: 86.9% winrate, +30.7c PnL/trade
# Logic: in last ~15s of 5min candle, if Binance price is clearly leading
# (>=0.01% above/below PTB), buy that side at ask if price is in [0.30, 0.75].
FL_ENABLED=true
FL_PAPER_ONLY=true
FL_ALLOWED_ASSETS=BTC,ETH

# Time window: only trade in the final seconds of the candle.
FL_MIN_SECS_LEFT=5
FL_MAX_SECS_LEFT=15

# Lead requirement: Binance price must be at least this fraction away from PTB.
# 0.0001 = 0.01% (e.g. ~$10 lead on $100k BTC).
FL_MIN_LEAD_PCT=0.0001
# Fallback bias used only for the first ~2s at startup (before 30 live samples
# are collected). After that _get_dynamic_bias() takes over automatically.
# Based on measured Binance-PTB spread of 10-19 bps — 12 bps is a safe default.
FL_DOWN_BIAS_OFFSET=0.0012
FL_DOWN_REQUIRE_PM_AGREE=false

# Polymarket book filters: skip too-cheap (no edge) and too-expensive (bad R/R).
# v3 data: 0.30-0.40 bucket = 31.5% WR (-$20.45); 0.35+ retains the positive bands.
FL_MIN_ENTRY_ASK=0.35
FL_MAX_ENTRY_ASK=0.75

# ── Time filters (data-driven from v3 1113-trade analysis) ────────────────────
# Skip these UTC hours (CSV). v3 worst: 00 (45% WR, -$28.70), 02 (45%, -$31.30),
# 08 (51%, breakeven), 17 (52%, -$14.35). Default per user: 0,1,8,9.
FL_SKIP_HOURS_UTC=0,1,8,9
# Skip Saturday + Sunday (weekday >= 5). v3: Sat 198 trades, 54.5% WR, +$1.95 (deadweight).
FL_SKIP_WEEKENDS=true

# Trade sizing.
FL_FIXED_SHARES=5
FL_MAX_OPEN_TRADES=2

FL_SCAN_STATS_INTERVAL=1.0
