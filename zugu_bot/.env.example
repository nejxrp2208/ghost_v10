# ──────────────────────────────────────────────────────────────────────────────
#  ZUGU v3.5 — Configuration
#  Copy this file to .env and fill in your own values. .env is gitignored.
#  Every setting has a sensible default; you can run the bot with an EMPTY .env.
# ──────────────────────────────────────────────────────────────────────────────


# ── Mode ─────────────────────────────────────────────────────────────────────
PAPER_TRADE=true                  # false = real money via Polymarket CLOB
PORTFOLIO_SIZE=200.0              # starting balance shown on dashboard (paper only)
QUIET_MODE=false                  # true = suppress per-tick ENTRY/SKIP logs
FL_RESET_ON_START=false           # true = wipe trades/events/scan_stats on startup


# ── FOLLOW LEADER strategy ───────────────────────────────────────────────────
# Logic: in last 5–15s of a 5min candle, if Binance leads PTB by ≥ FL_MIN_LEAD_PCT
# (adjusted for the rolling Chainlink bias), fire that side at the book ask.
FL_ENABLED=true
FL_PAPER_ONLY=true                # extra safety — bot fires ONLY in paper unless flipped
FL_ALLOWED_ASSETS=BTC,ETH

FL_MIN_SECS_LEFT=5
FL_MAX_SECS_LEFT=15

FL_MIN_LEAD_PCT=0.0001            # 0.01% — Binance must lead PTB by ≥ this
FL_DOWN_BIAS_OFFSET=0.0012        # static fallback bias (12bps) until 30 live samples collected
FL_DOWN_REQUIRE_PM_AGREE=false    # PM oracle has same lag as PTB; gating on it kills DOWN

FL_MIN_ENTRY_ASK=0.35             # v3: 0.30-0.40 bucket = 31.5% WR — cut
FL_MAX_ENTRY_ASK=0.75             # higher than this = bad R/R


# ── Risk-based sizing (single source of truth) ───────────────────────────────
# Every trade risks exactly FL_RISK_USDC. Shares = FL_RISK_USDC / ask_price.
# Max loss per trade = FL_RISK_USDC (since losing leg → $0).
FL_RISK_USDC=2.0

FL_MAX_OPEN_TRADES=2              # cap on simultaneously open positions


# ── Time filters (data-driven from v3's 1113-trade run) ──────────────────────
# Skip UTC hours where v3 showed losses or noise.
FL_SKIP_HOURS_UTC=0,1,8,9         # v3 worst: 00 -$28.70, 02 -$31.30, 08 breakeven, 17 -$14.35
FL_SKIP_WEEKENDS=true             # v3 Sat 198 trades, 54.5% WR, +$1.95 (deadweight)


# ── Account-survival guardrails (all default 0 = DISABLED) ───────────────────
# When non-zero, the bot halts BEFORE placing a new trade if the limit is hit.
# Identical pattern to ghost_predator. Zero impact on v3 behavior until enabled.
FL_DAILY_LOSS_LIMIT=0             # halt UTC day if today PnL <= -$N    (e.g. 20)
FL_ROLLING_24H_LIMIT=0            # halt if trailing 24h PnL <= -$N      (e.g. 15)
FL_MAX_LOSS_STREAK=0              # halt if last N resolved all losses    (e.g. 10)


# ── Telegram alerts (optional — empty creds = silent no-op) ──────────────────
# Every ZUGU message is prefixed with 🔮 ZUGU so it's distinguishable from
# other bots' alerts (e.g. predator uses 🎯).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FL_TG_ENTRY_ALERT=false           # alert on every fire (~50/day — can spam)
# Resolve alerts (win/loss) are always on if creds present (handled in resolver).


# ── State writer (for dashboard) ─────────────────────────────────────────────
FL_STATE_POLL_SECS=1.0            # how often to refresh state.json (1Hz)


# ── Live trading (only used when PAPER_TRADE=false) ─────────────────────────
# Credentials. Same wallet/API setup as ghost_predator.
PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# Live-mode tuning
FL_FILL_TIMEOUT_SEC=30            # cancel unfilled GTC orders after N sec
FL_PREWARM_NEAR_CLOSE_SEC=60      # keep TLS hot when any market ≤ N sec from close
FL_PREWARM_INTERVAL_SEC=5         # ping CLOB every N sec while warming


# ── Internal (rarely touched) ────────────────────────────────────────────────
FL_TIER=2
FL_SCAN_STATS_INTERVAL=1.0
FL_SPREAD_WINDOW_SEC=60
