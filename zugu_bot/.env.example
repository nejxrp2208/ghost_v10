# ── General mode ─────────────────────────────────────────────────────────────
PAPER_TRADE=true
PORTFOLIO_SIZE=200.0

# ── CREDENTIALS (fill in for LIVE mode — leave blank for paper) ──────────────
PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# ── TELEGRAM ALERTS (optional) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── FOLLOW LEADER strategy (late-candle momentum) ────────────────────────────
# Backtest result on ~465 candles: 86.9% winrate, +30.7c PnL/trade
# Logic: in last ~15s of 5min candle, if Binance price is clearly leading
# (>=0.01% above/below PTB), buy that side at ask if price is in [0.30, 0.75].
FL_ENABLED=true
FL_PAPER_ONLY=true
FL_ALLOWED_ASSETS=BTC,ETH

# Time window: only trade in the final seconds of the candle.
FL_MIN_SECS_LEFT=5
FL_MAX_SECS_LEFT=15

# Lead requirement: Binance price must be at least this fraction away from PTB.
# 0.0001 = 0.01% (e.g. ~$10 lead on $100k BTC).
FL_MIN_LEAD_PCT=0.0001

# Polymarket book filters: skip too-cheap (no edge) and too-expensive (bad R/R).
FL_MIN_ENTRY_ASK=0.30
FL_MAX_ENTRY_ASK=0.75

# Trade sizing.
FL_FIXED_SHARES=5
FL_MAX_OPEN_TRADES=2

FL_SCAN_STATS_INTERVAL=1.0
